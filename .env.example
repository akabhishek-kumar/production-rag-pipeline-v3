GROQ_API_KEY=gsk_
GROQ_MODEL=llama-3.1-8b-instant

PERSIST_DIR=./chroma_db
DOCS_DIR=./docs
BM25_INDEX_PATH=./bm25_index.pkl

CHUNK_SIZE=500
CHUNK_OVERLAP=50

BM25_K=10
VECTOR_K=10
RERANKER_K=5
RERANKER_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

GRADE_THRESHOLD=6
MAX_RETRIES=2
RECURSION_LIMIT=25

# ── Observability — v3 ────────────────────────────────────────────────────────

METRICS_DB_PATH=./metrics.db

# Langfuse LLM tracing (optional — leave blank to disable)
# Sign up free at https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# LangSmith tracing (optional — native LangGraph support, zero code changes)
# Sign up free at https://smith.langchain.com → Settings → API Keys
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=production-rag-v3

# CI regression gate thresholds
CI_MAX_P95_LATENCY_MS=8000.0
CI_MIN_AVG_QUALITY=5.0
CI_MIN_CITATION_RATE=0.5
